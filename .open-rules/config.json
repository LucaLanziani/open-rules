{
  "rulesDir": ".open-rules",
  "includeExtensions": [
    ".md",
    ".txt",
    ".mdc"
  ],
  "excludeFiles": [
    "README.md",
    "config.json"
  ],
  "rules": {},
  "targets": {
    "copilot": {
      "enabled": true,
      "path": ".github/copilot-instructions.md",
      "sourceMode": "reference"
    },
    "cursor": {
      "enabled": true,
      "path": ".cursor/rules/open-rules.mdc",
      "sourceMode": "reference"
    },
    "claude": {
      "enabled": true,
      "path": "CLAUDE.md",
      "sourceMode": "reference"
    }
  }
}
{
    "name": "open-rules",
    "version": "0.1.2",
    "description": "Consolidate agent rules into .open-rules and sync to Copilot/Cursor/Claude formats.",
    "type": "commonjs",
    "bin": {
        "open-rules": "bin/open-rules.js"
    },
    "scripts": {
        "sync": "node ./bin/open-rules.js sync",
        "init": "node ./bin/open-rules.js init",
        "check": "node ./bin/open-rules.js sync --dry-run",
        "test": "node --test test/**/*.test.js",
        "clean:ignored": "git clean -Xdf"
    },
    "keywords": [
        "ai",
        "rules",
        "copilot",
        "cursor",
        "claude"
    ],
    "license": "MIT"
}
